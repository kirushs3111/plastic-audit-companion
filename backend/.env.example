# Copy this file to .env and fill in real values for local development.
# In production (Railway/Render), set these as environment variables instead.

ENVIRONMENT=development

# PostgreSQL connection string
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/pac_dev

# Generate a real secret for anything beyond local dev, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=dev-only-insecure-secret-change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Comma-separated list is not supported directly by pydantic-settings list
# parsing from env vars in all cases - easiest is to override via a .env
# file using JSON array syntax:
FRONTEND_ORIGINS=["http://localhost:3000"]

# Local photo upload storage - swap for Cloudinary/Firebase later
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=8
